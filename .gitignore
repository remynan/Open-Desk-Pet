# Heavy / generated artifacts
node_modules/
.venv/
__pycache__/
*.pyc
*.pyo
.DS_Store
*.log

# Build / dist outputs
dist/
# Ignore PyInstaller intermediates / output but keep the source-of-truth
# spec and build script committed.
build/*
!build/sidecar.spec
!build/build-sidecar.sh

# Model weights — too big to ship, friends/colleagues download separately
models/

# Editor / OS junk
.vscode/
.idea/
*.swp
*~

# Local env / secrets
.env
.env.local

# Bridge runtime files
*.pid
runtime-port.json

# uv lock — keep
# (don't ignore uv.lock; it's needed for reproducible installs)
